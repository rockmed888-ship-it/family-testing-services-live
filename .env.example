# API
PORT=8787
API_ORIGIN=http://localhost:8787
WEB_ORIGIN=http://localhost:5173
JWT_SECRET=change-me-in-production

# Database (Railway Postgres in production — enables persistent WWH2 feedback)
DATABASE_URL=postgres://user:pass@host:5432/secretlayer
# PGSSLMODE=disable

# WWH2 feedback fallback when DATABASE_URL is unset (local dev)
WWH2_DATA_DIR=./data

# Promotion (optional — used when checks pass)
NETLIFY_AUTH_TOKEN=
NETLIFY_SITE_ID=
PROMOTION_WEBHOOK_URL=
