PORT=3000
NODE_ENV=development

# Required in production. Use a unique strong password.
ADMIN_PASSWORD=replace-with-a-long-private-password

# Required in production. Generate separate random values and do not rotate
# DATA_ENCRYPTION_KEY without first decrypting/migrating the stored records.
SESSION_SECRET=replace-with-at-least-32-random-characters
DATA_ENCRYPTION_KEY=replace-with-at-least-32-random-characters

# Local default is ./data. On Render with the included persistent disk use /var/data.
DATA_DIR=./data
SESSION_HOURS=8
