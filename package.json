{
  "name": "secretlayer",
  "version": "0.2.0",
  "private": true,
  "description": "SecretLayer — vault-first secrets for builders. Projects, encrypted vaults, safety nets, and promotion gates.",
  "packageManager": "pnpm@10.33.3",
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "dev:web": "pnpm --filter @secretlayer/web dev",
    "dev:family-testing": "python3 -m http.server 8080 --bind 0.0.0.0 --directory family-testing-services",
    "dev:api": "pnpm --filter @secretlayer/api dev",
    "build:netlify": "pnpm --filter @secretlayer/web build",
    "build:railway": "pnpm run build:netlify && pnpm --filter @secretlayer/api build",
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "safety:run": "pnpm --filter @secretlayer/safety-engine cli",
    "promote:check": "pnpm --filter @secretlayer/promotion cli"
  },
  "engines": {
    "node": ">=20"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
